                    "script": {
                        "exec": [
                            "// If client is ENTERPRISE this returns 200.",
                            "// If client is LITE/CORE/PRO it should return 403 FEATURE_NOT_IN_PLAN.",
                            "pm.test('Either 200 (ENTERPRISE) or 403 (lower plan)', () => {",
