                                "key": "Authorization",
                                "value": "Bearer {{CLIENT_TOKEN}}"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/project/{{PM_ID}}",
                        "body": {
                            "mode": "raw",
                            "raw": "{\"assignedSites\": [\"{{SITE_ID}}\"]}"
                        }
                    }
                }
            ]
