{
    "info": {
        "name": "ANPR — Dedicated DB Verification",
        "_postman_id": "anpr-dedicated-db-test",
        "description": "Tests to verify that ENTERPRISE clients with a provisioned dedicated DB have their data isolated correctly.\n\n## How to use\n1. Run '0. Setup' folder top-to-bottom once to get tokens + IDs.\n2. Copy the returned IDs into the collection variables.\n3. Run the numbered folders in order.\n4. After each write, open MongoDB Compass on BOTH the shared DB and the dedicated DB and confirm data landed in the right place.\n\n## Variables (set these in the collection)\n- BASE_URL          → http://localhost:5000\n- SUPERADMIN_TOKEN  → filled by step 0.1\n- CLIENT_TOKEN      → filled by step 0.3 (client-admin login)\n- PM_TOKEN          → filled by step 0.5\n- SUPERVISOR_TOKEN  → filled by step 0.6\n- CLIENT_ID         → filled by step 0.2\n- SITE_ID           → filled by step 1.1\n- VENDOR_ID         → filled by step 2.1\n- TRIP_ID           → filled by step 3.1",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "BASE_URL",
            "value": "http://localhost:5000"
        },
        {
            "key": "SUPERADMIN_TOKEN",
            "value": ""
        },
        {
            "key": "CLIENT_TOKEN",
            "value": ""
        },
        {
            "key": "PM_TOKEN",
            "value": ""
        },
        {
            "key": "SUPERVISOR_TOKEN",
            "value": ""
        },
        {
            "key": "CLIENT_ID",
            "value": ""
        },
        {
            "key": "SITE_ID",
            "value": ""
        },
        {
            "key": "VENDOR_ID",
            "value": ""
        },
        {
            "key": "TRIP_ID",
            "value": ""
        },
        {
            "key": "PM_ID",
            "value": ""
        },
        {
            "key": "SUPERVISOR_ID",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "0. Setup — Auth & Provision",
            "item": [
                {
                    "name": "0.1 SuperAdmin Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var r = pm.response.json();",
                                    "pm.collectionVariables.set('SUPERADMIN_TOKEN', r.accessToken);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"superadmin@example.com\",\"password\":\"yourpassword\"}"
                        }
                    }
                },
                {
                    "name": "0.2 Create ENTERPRISE Client",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var r = pm.response.json();",
                                    "pm.collectionVariables.set('CLIENT_ID', r.data._id);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{SUPERADMIN_TOKEN}}"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/superadmin/clients",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"clientname\": \"Enterprise Test Client\",\n  \"companyName\": \"EnterpriseCo\",\n  \"email\": \"enterprise@test.com\",\n  \"phone\": \"9999999999\",\n  \"password\": \"Test@1234\",\n  \"packageType\": \"ENTERPRISE\",\n  \"packageStart\": \"2025-01-01\",\n  \"packageEnd\": \"2026-01-01\"\n}"
                        }
                    }
                },
                {
                    "name": "0.3 Provision Dedicated DB",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{SUPERADMIN_TOKEN}}"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/superadmin/clients/{{CLIENT_ID}}/provision-db",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"connectionString\": \"mongodb+srv://user:pass@dedicated-cluster.mongodb.net\",\n  \"dbName\": \"enterprise_test_db\"\n}"
                        }
                    }
                },
                {
                    "name": "0.4 Client Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var r = pm.response.json();",
                                    "pm.collectionVariables.set('CLIENT_TOKEN', r.accessToken);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"enterprise@test.com\",\"password\":\"Test@1234\"}"
                        }
                    }
                },
                {
                    "name": "0.5 Create Project Manager",
