                    "name": "4.1 Create Manual Trip (entry) ✅ dedicated",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('201 created', () => pm.response.to.have.status(201));",
                                    "var r = pm.response.json();",
                                    "pm.collectionVariables.set('TRIP_ID', r.tripId || r.data?._id);",
                                    "pm.test('tripId returned', () => pm.expect(r.tripId || r.data?._id).to.exist);",
