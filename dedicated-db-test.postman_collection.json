                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{CLIENT_TOKEN}}"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/project",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Test PM\",\n  \"email\": \"pm@enterprise.com\",\n  \"mobile\": \"8888888888\",\n  \"password\": \"PM@1234\"\n}"
                        }
                    }
                },
                {
                    "name": "0.6 PM Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var r = pm.response.json();",
                                    "pm.collectionVariables.set('PM_TOKEN', r.accessToken);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/auth/login",
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\":\"pm@enterprise.com\",\"password\":\"PM@1234\"}"
                        }
                    }
                }
            ]
        },
        {
            "name": "1. Sites — should land in dedicated DB",
            "item": [
                {
                    "name": "1.1 Create Site ✅ dedicated",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('201 created', () => pm.response.to.have.status(201));",
                                    "var r = pm.response.json();",
                                    "pm.collectionVariables.set('SITE_ID', r._id);",
                                    "pm.test('site has _id', () => pm.expect(r._id).to.be.a('string'));"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{CLIENT_TOKEN}}"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/sites",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Enterprise Site A\",\n  \"location\": \"Mumbai\",\n  \"address\": \"123 Test Street\",\n  \"gates\": [{\"gateName\": \"Main Gate\", \"isMainGate\": true}]\n}"
                        }
                    }
                },
                {
                    "name": "1.2 Get All Sites ✅ dedicated",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('200 ok', () => pm.response.to.have.status(200));",
                                    "var r = pm.response.json();",
                                    "pm.test('returns array', () => pm.expect(r.data || r).to.be.an('array'));",
                                    "pm.test('server log should show dedicated DB connection', () => pm.expect(true).to.be.true);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{CLIENT_TOKEN}}"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/sites"
                    }
                },
                {
                    "name": "1.3 Update Site ✅ dedicated",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{CLIENT_TOKEN}}"
                            }
                        ],
                        "url": "{{BASE_URL}}/api/sites/{{SITE_ID}}",
                        "body": {
                            "mode": "raw",
                            "raw": "{\"name\": \"Enterprise Site A — Updated\"}"
                        }
                    }
